# OrcheStack — Environment variables.
#
# To use:
#   1. Copy this file to `.env` in the same directory.
#   2. Set POSTGRES_PASSWORD to a strong value (do NOT use the placeholder).
#   3. Run `docker compose up -d`.
#
# The .env file is gitignored — never commit real secrets.

# ============================================================================
# Platform PostgreSQL credentials.
# These create the database superuser and database on first container start.
# Used by every service that connects to PostgreSQL (the orchestrator, later
# Streamlit, later dbt, later Airbyte for its metadata, etc.).
# ============================================================================
POSTGRES_USER=orchestack
POSTGRES_PASSWORD=changeme-set-a-strong-password-before-running
POSTGRES_DB=orchestack

# ============================================================================
# Image tags.
# Pin to a specific immutable version (e.g. 0.1.0) in production deployments
# so an upstream rebuild doesn't silently change behaviour. `latest` is fine
# for development and CI smoke tests.
# ============================================================================
AUTH_TAG=latest
# ORCHESTRATOR_TAG=latest   # uncomment at M2 when the real image is built
# STREAMLIT_TAG=latest      # uncomment at M3
# AIRFLOW_TAG=latest        # uncomment at M4

# ============================================================================
# Host port mappings.
# Override these if port 80/443 are already in use on the host, or if you
# want to expose OrcheStack on a non-standard port for development.
# Examples:
#   PROXY_HTTP_PORT=1993        → http://localhost:1993
#   PROXY_HTTPS_PORT=1994       → https://localhost:1994
#   PROXY_DASHBOARD_PORT=18080  → http://localhost:18080/dashboard/
# Leave commented to use the defaults (80, 443, 8080).
# ============================================================================
# PROXY_HTTP_PORT=80
# PROXY_HTTPS_PORT=443
# PROXY_DASHBOARD_PORT=8080
