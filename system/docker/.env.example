# OrcheStack — Environment variables.
#
# To use:
#   1. Copy this file to `.env` in the same directory.
#   2. Set ORCHESTACK_DB_PASSWORD ONLY to a strong value (do NOT use the placeholder).
#   3. DO NOT commit `.env` to git — it contains secrets.
#   4. DO NOT CHANGES here as it'll break the system. Use the setup wizard to fill in the rest of the values.
#   5. Run `docker compose up -d`.
#   6. Visit http://localhost/setup to complete the wizard. It fills in the
#      blank values below in place (line-preserving) so this layout stays
#      readable after the install.
#
# The .env file is gitignored — never commit real secrets.
#
# ============================================================================
# OrcheStack internal database — bootstrap credentials
# ============================================================================
# OrcheStack runs TWO logical PostgreSQL databases inside one Postgres container:
#
#   1. The OrcheStack internal database (ORCHESTACK_DB_* below)
#      ─ Holds OrcheStack's own state: users, roles, sessions, audit log,
#        service-pinning, installed-service registry. Schema: `platform`.
#      ─ Small and bounded — does not grow with the volume of your data.
#      ─ Bootstrap credentials. Set ONCE here in .env, before first boot.
#        Cannot be changed from inside the running system because Postgres
#        initialises the superuser on first volume creation only.
#
#   2. The customer warehouse database (WAREHOUSE_DB_* below)
#      ─ Holds YOUR data: raw landing tables, dbt marts, Airflow metadata.
#      ─ Grows with your business. Different user, different DB name.
#      ─ Created and configured during the in-browser setup wizard
#        (http://localhost/setup/configure → PostgreSQL section).
#
# Keeping them separate means a backup of OrcheStack's metadata is cheap and
# fast, while warehouse backups can follow your own data-retention policy.
# ============================================================================
ORCHESTACK_DB_USER=orchestack_admin
ORCHESTACK_DB_PASSWORD=changeme-set-a-strong-password-before-running
ORCHESTACK_DB_NAME=orchestack_db

# ============================================================================
# Image tags.
# Pin to a specific immutable version (e.g. 0.1.0) in production deployments
# so an upstream rebuild doesn't silently change behaviour. `latest` is fine
# for development and CI smoke tests.
# ============================================================================
AUTH_TAG=latest
ORCHESTRATOR_TAG=latest
DASHBOARD_TAG=latest

# ============================================================================
# Host port mappings.
# Override these if port 80/443 are already in use on the host, or if you
# want to expose OrcheStack on a non-standard port for development.
# Examples:
#   PROXY_HTTP_PORT=1993        → http://localhost:1993
#   PROXY_HTTPS_PORT=1994       → https://localhost:1994
#   PROXY_DASHBOARD_PORT=18080  → http://localhost:18080/dashboard/
# Leave commented to use the defaults (80, 443, 8080).
# ============================================================================
# PROXY_HTTP_PORT=80
# PROXY_HTTPS_PORT=443
# PROXY_DASHBOARD_PORT=8080

# ============================================================================
# Warehouse database — your data (filled by the wizard).
# ============================================================================
# The warehouse runs inside the shared orchestack-postgres container as a
# separate database from the OrcheStack internal one. Host/Port are fixed
# by the deployment topology and should not be edited manually.
WAREHOUSE_DB_HOST=orchestack-postgres
WAREHOUSE_DB_PORT=5432
WAREHOUSE_DB_USER=warehouse_admin
WAREHOUSE_DB_PASSWORD=
WAREHOUSE_DB_NAME=

# ============================================================================
# dbt — transformation models on the warehouse.
# ============================================================================
# DBT_DB_USER is the role dbt connects to the warehouse as. Defaults to
# dbt_admin (created by the orchestrator's pre-start hook). DBT_REPO_URL is
# optional: leave blank to use the built-in demo project (warehouse_tables);
# set it to your own GitHub repo to track that project instead.
DBT_DB_USER=dbt_admin
DBT_DB_PASSWORD=
DBT_REPO_URL=
DBT_REPO_BRANCH=

# ============================================================================
# Airflow — webserver + scheduler in one container, LocalExecutor.
# ============================================================================
# AIRFLOW_DB_* are credentials for Airflow's OWN metadata database
# (separate from your warehouse). AIRFLOW_ADMIN_* are the login for the
# Airflow web UI. AIRFLOW_DAGS_REPO_URL is optional: set it to a GitHub
# repo URL to sync DAGs from that repo on every scheduler tick.
AIRFLOW_DB_USER=airflow_admin
AIRFLOW_DB_PASSWORD=
AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=
AIRFLOW_ADMIN_USERNAME=
AIRFLOW_ADMIN_EMAIL=
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_DAGS_REPO_URL=
AIRFLOW_DAGS_REPO_BRANCH=

# ============================================================================
# Metabase — BI dashboards on the warehouse.
# ============================================================================
# METABASE_DB_* are credentials for Metabase's OWN application database
# (where it stores dashboards, questions, user settings). Metabase reads
# the warehouse using the warehouse_admin role — no separate auth needed.
METABASE_DB_USER=metabase_admin
METABASE_DB_PASSWORD=

# ============================================================================
# Airbyte — connector-based ingestion into the warehouse.
# ============================================================================
# AIRBYTE_DB_* are credentials for Airbyte's OWN application database
# (where it stores connector configs, sync state, job history). Airbyte has
# no separate login UI — access to the workspace is gated by OrcheStack's
# platform auth via the forward-auth chain.
AIRBYTE_DB_USER=airbyte_admin
AIRBYTE_DB_PASSWORD=

# ============================================================================
# MinIO — S3-compatible object storage for cold-tier files.
# ============================================================================
# MINIO_ROOT_USER/PASSWORD are the bootstrap admin login for MinIO's web
# console and the S3 API. Operators can create scoped service accounts
# from the MinIO console after first login.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# ============================================================================
# Great Expectations — data quality validation against the warehouse.
# ============================================================================
# GE has no separate database — it validates the warehouse using the
# warehouse_admin role. GE_REPO_URL is optional: leave blank to use the
# built-in demo suite (validates pg_catalog.pg_tables); set it to your
# own GitHub repo to track that project's expectations + checkpoints.
GE_REPO_URL=
GE_REPO_BRANCH=

# ============================================================================
# OpenMetadata — data catalogue + lineage.
# ============================================================================
# OPENMETADATA_DB_* are credentials for OpenMetadata's OWN application
# database (where it stores entity records, lineage, glossary terms).
# OPENMETADATA_ADMIN_EMAIL is the OpenMetadata UI login (email-shaped;
# never used to send mail). OPENMETADATA_JWT_SECRET signs auth tokens
# issued by OpenMetadata's server; rotate from the admin UI when needed.
OPENMETADATA_DB_USER=openmetadata_admin
OPENMETADATA_DB_PASSWORD=
OPENMETADATA_ADMIN_EMAIL=
OPENMETADATA_ADMIN_PASSWORD=
OPENMETADATA_JWT_SECRET=
